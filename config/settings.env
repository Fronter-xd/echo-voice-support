# Echo Voice Support Configuration

# STT Settings (Whisper)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_AUDIO_LENGTH=30

# LLM Settings (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_NUM_ctx=4096
LLM_TIMEOUT=30

# TTS Settings (Edge-TTS)
TTS_VOICE=en-IN-NeerjaNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%

# Alternative TTS Voices (Indian Accents)
# en-IN-NeerjaNeural - Female, Indian accent
# en-IN-PrabhatNeural - Male, Indian accent
# hi-IN-MadhurNeural - Hindi, Female
# ta-IN-PallaviNeural - Tamil, Female

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024

# Performance Settings
VAD_ENABLED=true
VAD_THRESHOLD=0.5
VAD_SILENCE_TIMEOUT_MS=1000
STREAMING_MODE=true
PARALLEL_TTS=true

# WebSocket Settings
WS_HOST=0.0.0.0
WS_PORT=8765
WS_MAX_CONNECTIONS=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
